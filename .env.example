# Local-first production defaults
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_SUPABASE_SYNC=false

# Optional text AI provider
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TEXT_MODELS=gemini-3.5-flash,gemini-3.1-flash-lite,gemini-2.5-flash,gemini-2.5-flash-lite
AI_MODEL_TIMEOUT_MS=20000
AI_STORY_SUGGEST_TIMEOUT_MS=45000
AI_DEMO_FALLBACK_ENABLED=true
AI_DEBUG_LOGS=false

# Optional image providers
IMAGE_BACKEND_URL=
NEXT_PUBLIC_IMAGE_BACKEND_URL=
HUGGINGFACE_API_TOKEN=
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
NEXT_PUBLIC_HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
HF_INFERENCE_PROVIDER=nscale
HF_IMAGE_ENDPOINT=https://router.huggingface.co/nscale/v1/images/generations
HF_IMAGE_SIZE=1024x1024
IMAGEN_IMAGE_MODELS=imagen-4.0-generate-001
GEMINI_IMAGE_MODELS=imagen-4.0-generate-001

# Optional Kaggle async image jobs
KAGGLE_ENABLED=false
NEXT_PUBLIC_KAGGLE_ENABLED=false
KAGGLE_USERNAME=
KAGGLE_KEY=
KAGGLE_API_TOKEN=
KAGGLE_KERNEL_REF=
KAGGLE_INPUT_DATASET_REF=
KAGGLE_OUTPUT_FILE=output.png
KAGGLE_MAX_POLL_ATTEMPTS=90
KAGGLE_JOB_STORE=supabase
KAGGLE_DIFFUSION_MODEL=Meina/MeinaMix_V11
NEXT_PUBLIC_KAGGLE_DIFFUSION_MODEL=Meina/MeinaMix_V11

# Optional Supabase/cloud sync
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
